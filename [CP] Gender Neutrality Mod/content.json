	"ConfigSchema":
		{
			"ReplaceGenderSymbols":
				{
					"AllowValues": "true, false",
					"Default": "true",
					"Description": "Changes the male and female gender symbols into a 1 and 2.",
					"Section": "General Settings"
				},
			"FixBathHouseDoors":
				{
					"AllowValues": "true, false",
					"Default": "true",
					"Description": "Allows player to enter either door at the bath house.",
					"Section": "General Settings"
				},
			"FixBathHouseTiles":
				{
					"AllowValues": "true, false",
					"Default": "true",
					"Description": "Removes the 'W' and 'M' from the bath house doors.",
					"Section": "General Settings"
				},
			"FixOtherPlayers":
				{
					"AllowValues": "true, false",
					"Default": "true",
					"Description": "Changes multiplayer messages to use pronoun settings below.",
					"Section": "General Settings"
				},
			"OtherPlayerSubjectivePronoun":
				{
					"AllowBlank": "true",
					"AllowMultiple": "true",
					"Default": "They",
					"Description": "The subjective pronoun to use for other players. (i.e. He, She, They, etc.)",
					"Section": "Pronoun Settings"
				},
			"OtherPlayerObjectivePronoun":
				{
					"AllowBlank": "true",
					"AllowMultiple": "true",
					"Default": "Them",
					"Description": "The objective pronoun to use for other players. (i.e. Him, Her, Them, etc.)",
					"Section": "Pronoun Settings"
				},
			"OtherPlayerPossessivePronoun":
				{
					"AllowBlank": "true",
					"AllowMultiple": "true",
					"Default": "Their",
					"Description": "The possessive pronoun to use for other players. (i.e. His, Her, Their, etc.)",
					"Section": "Pronoun Settings"
				},
			"Priority":
				{
					"AllowValues": "Early, Default, Late",
					"Default": "Default",
					"Desription": "Load order for the mod. Early for best compatibility. Late for most control over edits.",
					"Section": "Priority Settings"
				}
		},
